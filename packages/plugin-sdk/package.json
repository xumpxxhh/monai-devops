{
  "name": "@monai-devops/plugin-sdk",
  "version": "1.0.0",
  "description": "Plugin contract and helpers for monai-devops",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "check-types": "tsc --noEmit -p tsconfig.build.json"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "ISC",
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.18.2"
}
